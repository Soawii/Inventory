<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= locals.title || 'Create Category' %></title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include("partials/header") %>

    <main class="createcategory-main">
        <form class="createcategory-form" method="post" action="<%= locals.action || '/categories/create' %>">
            <div class="createcategory-form-title"><%= locals.title || 'Create Category' %></div>
            <label for="input-title">
                Title
                <input type="text" name="title" id="input-title" value="<%= (locals.formdata && formdata.title) || '' %>">
            </label>
            <%- include("partials/errors") %>
            <button type="submit">Submit</button>
        </form>
    </main>

    <%- include("partials/footer") %>
</body>
</html>